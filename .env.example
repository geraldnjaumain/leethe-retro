# Server-only TMDB credentials. Prefer the read-access token.
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=
TMDB_API_BASE_URL=
TMDB_IMAGE_BASE_URL=

# Least-privileged Neon application connection.
DATABASE_URL=
# Owner/admin connection used only by `npm run db:migrate`.
DATABASE_ADMIN_URL=
# Optional comma-separated catalog title shards. DATABASE_URL remains the control database.
CATALOG_DATABASE_SHARD_URLS=
# Matching owner/admin URLs used only by migration, role, and verification scripts.
CATALOG_DATABASE_SHARD_ADMIN_URLS=
# Optional source used by `npm run db:reshard-catalog`; defaults to DATABASE_URL.
CATALOG_RESHARD_SOURCE_URL=

# Server-only stream resolver keys, matching the companion Astro player.
MOVIEBOX_SECRET_KEY_DEFAULT=
MOVIEBOX_SECRET_KEY_ALT=
# Comma-separated provider endpoints. Override these without changing application code.
MOVIEBOX_API_HOSTS=
MOVIEBOX_H5_API_HOST=
MOVIEBOX_WEB_ORIGIN=
# Dedicated HMAC secret for signed sports playlist/segment proxy URLs.
# Falls back to MOVIEBOX_SECRET_KEY_DEFAULT when omitted.
SPORTS_STREAM_PROXY_SECRET=

# The external stream resolver stays disabled unless both are true.
ENABLE_EXTERNAL_STREAM_RESOLVER=false
STREAMING_RIGHTS_CONFIRMED=false

# First-party aggregate product events and password-protected operations dashboard.
ENABLE_PRODUCT_ANALYTICS=false
# Optional, but must be at least 16 characters when configured in production.
ADMIN_PASSWORD=

# Production origin and operational settings.
SITE_URL=https://example.com
LEGAL_CONTACT_EMAIL=legal@example.com
TRUST_PROXY=false
LOG_LEVEL=info

# Optional generic JSON webhook for failed production workflows.
ALERT_WEBHOOK_URL=

# Optional persistent directory. Leave empty on ephemeral/serverless hosts.
LOCAL_CACHE_DIR=
