{
  "name": "leethe",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node postcss-standalone.mjs",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "start": "node --env-file-if-exists=.env scripts/serve.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:workflows": "node scripts/validate-workflows.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run validate:workflows && npm run build",
    "smoke:production": "node --env-file-if-exists=.env scripts/smoke-production.mjs",
    "db:migrate": "node --env-file-if-exists=.env scripts/migrate.mjs",
    "db:provision-app-role": "node --env-file-if-exists=.env scripts/provision-app-role.mjs",
    "db:apply-app-privileges": "node --env-file-if-exists=.env scripts/apply-app-privileges.mjs",
    "db:rotate-admin-password": "node --env-file-if-exists=.env scripts/rotate-admin-password.mjs",
    "db:refresh-catalog": "node --env-file-if-exists=.env scripts/refresh-catalog.mjs",
    "db:reshard-catalog": "node --env-file-if-exists=.env scripts/reshard-catalog.mjs",
    "db:cleanup": "node --env-file-if-exists=.env scripts/cleanup.mjs",
    "db:verify": "node --env-file-if-exists=.env scripts/verify-database.mjs",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/react-virtual": "^3.14.2",
    "@tanstack/router-plugin": "^1.167.28",
    "hls.js": "^1.6.15",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "srvx": "^0.11.17",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@csstools/postcss-cascade-layers": "^6.0.0",
    "@eslint/js": "^9.32.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "browserslist": "^4.28.2",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "glob": "^13.0.6",
    "globals": "^15.15.0",
    "lightningcss": "^1.32.0",
    "postcss": "^8.5.15",
    "postcss-preset-env": "^11.3.1",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  }
}
